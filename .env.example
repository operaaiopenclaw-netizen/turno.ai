# ─── DATABASE ────────────────────────────────────────────────────────────────
# Dev local:
DATABASE_URL="postgresql://postgres:senha@localhost:5432/turno?schema=public"
# Supabase (prod) — use Transaction mode pooler, porta 6543:
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Gerar secret: openssl rand -base64 32
AUTH_SECRET="cole-aqui-string-aleatoria-32plus-chars"
NEXTAUTH_SECRET="cole-aqui-string-aleatoria-32plus-chars"
NEXTAUTH_URL="http://localhost:3000"
# Produção: NEXTAUTH_URL="https://turno.ai"

# ─── CELCOIN (PIX / TED) — mock em dev se vazios ────────────────────────────
CELCOIN_BASE_URL="https://sandbox.openfinance.celcoin.dev"
CELCOIN_CLIENT_ID=""
CELCOIN_CLIENT_SECRET=""
CELCOIN_WEBHOOK_SECRET=""

# ─── BLOCKCHAIN (Polygon) — mock em dev se vazios ───────────────────────────
# Chave privada da wallet operadora
BLOCKCHAIN_PRIVATE_KEY=""
# Endereço do contrato TurnoPaymentRegistry (após deploy)
CONTRACT_ADDRESS=""
# amoy (testnet) ou mainnet
BLOCKCHAIN_NETWORK="amoy"
AMOY_RPC_URL="https://rpc-amoy.polygon.technology"
POLYGON_RPC_URL="https://polygon-rpc.com"
# Para verificar contrato no Polygonscan (opcional)
POLYGONSCAN_API_KEY=""

# ─── WHATSAPP (Z-API) — console.log em dev se vazios ───────────────────────
ZAPI_BASE_URL="https://api.z-api.io"
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""

# ─── EMAIL (Resend) — console.log em dev se vazio ───────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Turno.ai <noreply@turno.ai>"

# ─── KYC (Serpro) — mock em dev se vazio ────────────────────────────────────
SERPRO_API_KEY=""
SERPRO_BASE_URL="https://gateway.apiserpro.serpro.gov.br"

# ─── PLATAFORMA ───────────────────────────────────────────────────────────────
PLATFORM_FEE_RATE="0.12"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
