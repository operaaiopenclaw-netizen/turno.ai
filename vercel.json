{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "regions": ["gru1"],
  "env": {
    "DATABASE_URL": "@turno_database_url",
    "NEXTAUTH_SECRET": "@turno_nextauth_secret",
    "NEXTAUTH_URL": "@turno_nextauth_url",
    "CELCOIN_CLIENT_ID": "@turno_celcoin_client_id",
    "CELCOIN_CLIENT_SECRET": "@turno_celcoin_client_secret",
    "BLOCKCHAIN_PRIVATE_KEY": "@turno_blockchain_private_key",
    "CONTRACT_ADDRESS": "@turno_contract_address",
    "ZAPI_INSTANCE_ID": "@turno_zapi_instance_id",
    "ZAPI_TOKEN": "@turno_zapi_token",
    "RESEND_API_KEY": "@turno_resend_api_key",
    "SERPRO_API_KEY": "@turno_serpro_api_key"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
