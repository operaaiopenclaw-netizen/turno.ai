// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USERS ────────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(WORKER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  worker        Worker?
  company       Company?
  wallet        Wallet?
  notifications Notification[]
}

enum UserRole {
  WORKER
  COMPANY
  ADMIN
}

// ─── WORKER ───────────────────────────────────────────────────────────────────
model Worker {
  id              String          @id @default(cuid())
  userId          String          @unique
  cpf             String          @unique
  phone           String
  bio             String?
  address         String?
  pixKey          String?
  pixKeyType      PixKeyType?
  neighborhood    String?
  city            String          @default("Curitiba")
  state           String          @default("PR")
  latitude        Float?
  longitude       Float?
  rating          Float           @default(0)
  totalShifts     Int             @default(0)
  totalEarnings   Float           @default(0)
  cpfVerified     Boolean         @default(false)
  backgroundCheck BackgroundStatus @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       WorkerSkill[]
  applications Application[]
  timesheets   Timesheet[]
  reviews      Review[]      @relation("WorkerReviews")

  @@index([neighborhood])
  @@index([backgroundCheck])
  @@index([rating])
}

enum BackgroundStatus {
  PENDING
  CLEAR
  FLAGGED
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

model WorkerSkill {
  id       String @id @default(cuid())
  workerId String
  skill    String
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
}

// ─── COMPANY ──────────────────────────────────────────────────────────────────
model Company {
  id           String     @id @default(cuid())
  userId       String     @unique
  cnpj         String     @unique
  tradeName    String
  legalName    String
  phone        String
  address      String
  neighborhood String
  city         String     @default("Curitiba")
  state        String     @default("PR")
  latitude     Float?
  longitude    Float?
  pixKey       String?
  pixKeyType   PixKeyType?
  industry     Industry
  rating       Float      @default(0)
  totalShifts  Int        @default(0)
  verified     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts  Shift[]
  reviews Review[]  @relation("CompanyReviews")

  @@index([verified])
  @@index([industry])
}

enum Industry {
  HOSPITALITY
  EVENTS
  RETAIL
  LOGISTICS
  MANUFACTURING
  OTHER
}

// ─── SHIFT ────────────────────────────────────────────────────────────────────
model Shift {
  id           String      @id @default(cuid())
  companyId    String
  role         String
  description  String
  requirements String?
  dresscode    String?
  date         DateTime
  startTime    String      // "18:00"
  endTime      String      // "23:00"
  hours        Float
  payPerHour   Float
  totalPay     Float
  spots        Int         @default(1)
  filledSpots  Int         @default(0)
  category     Industry
  neighborhood String
  address      String?
  city         String      @default("Curitiba")
  latitude     Float?
  longitude    Float?
  status       ShiftStatus @default(OPEN)
  urgent       Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  timesheets   Timesheet[]
  payments     Payment[]
  reviews      Review[]

  @@index([companyId])
  @@index([status])
  @@index([date])
  @@index([category])
  @@index([neighborhood])
}

enum ShiftStatus {
  DRAFT
  OPEN
  FILLED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── APPLICATION ──────────────────────────────────────────────────────────────
model Application {
  id          String            @id @default(cuid())
  shiftId     String
  workerId    String
  status      ApplicationStatus @default(PENDING)
  message     String?
  appliedAt   DateTime          @default(now())
  decidedAt   DateTime?
  updatedAt   DateTime          @updatedAt

  shift     Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  timesheet Timesheet?
  payment   Payment?

  @@unique([shiftId, workerId])
  @@index([workerId])
  @@index([status])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CONFIRMED
  NO_SHOW
}

// ─── TIMESHEET ────────────────────────────────────────────────────────────────
model Timesheet {
  id             String          @id @default(cuid())
  applicationId  String          @unique
  shiftId        String
  workerId       String
  checkInAt      DateTime?
  checkInLat     Float?
  checkInLng     Float?
  checkOutAt     DateTime?
  checkOutLat    Float?
  checkOutLng    Float?
  hoursWorked    Float?
  status         TimesheetStatus @default(PENDING)
  approvedAt     DateTime?
  disputeNote    String?
  resolvedNote   String?
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  shift       Shift        @relation(fields: [shiftId], references: [id])
  worker      Worker       @relation(fields: [workerId], references: [id])
  payment     Payment?

  @@index([workerId])
  @@index([shiftId])
  @@index([status])
}

enum TimesheetStatus {
  PENDING
  APPROVED
  DISPUTED
  RESOLVED
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────────
model Payment {
  id               String        @id @default(cuid())
  shiftId          String
  applicationId    String        @unique
  timesheetId      String?       @unique
  amount           Float
  platformFee      Float
  netAmount        Float
  pixKey           String?
  pixKeyType       PixKeyType?
  pixE2eId         String?
  pixQrCode        String?
  blockchainTxHash String?
  blockchainBlock  BigInt?
  blockchainNetwork String?
  walletTxId       String?       // WalletTransaction ID do worker
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  shift        Shift        @relation(fields: [shiftId], references: [id])
  application  Application  @relation(fields: [applicationId], references: [id])
  timesheet    Timesheet?   @relation(fields: [timesheetId], references: [id])

  @@index([shiftId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

// ─── WALLET ───────────────────────────────────────────────────────────────────
// Carteira interna em BRLC (stablecoin 1:1 com BRL)
model Wallet {
  id           String   @id @default(cuid())
  userId       String   @unique
  balance      Decimal  @default(0) @db.Decimal(14, 2)   // saldo disponível
  reserved     Decimal  @default(0) @db.Decimal(14, 2)   // bloqueado em escrow
  totalIn      Decimal  @default(0) @db.Decimal(14, 2)
  totalOut     Decimal  @default(0) @db.Decimal(14, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  virtualCard  VirtualCard?
}

model WalletTransaction {
  id          String       @id @default(cuid())
  walletId    String
  type        WalletTxType
  amount      Decimal      @db.Decimal(14, 2)
  fee         Decimal      @default(0) @db.Decimal(14, 2)
  netAmount   Decimal      @db.Decimal(14, 2)
  status      TxStatus     @default(PENDING)
  reference   String?      // PIX e2eId, blockchain txHash, etc.
  description String?
  paymentId   String?
  meta        Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

enum WalletTxType {
  DEPOSIT_PIX       // empresa deposita BRL via PIX → BRLC
  DEPOSIT_BOLETO    // empresa deposita via boleto
  ESCROW_LOCK       // empresa reserva para pagamento de turno
  ESCROW_RELEASE    // worker recebe após aprovação
  ESCROW_REFUND     // devolve à empresa se cancelado
  CASHOUT_PIX       // worker saca para PIX
  CARD_SPEND        // worker gasta com cartão virtual
  CARD_REFUND       // estorno de cartão
  PLATFORM_FEE      // taxa da plataforma
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
  REVERSED
}

// ─── VIRTUAL CARD ─────────────────────────────────────────────────────────────
model VirtualCard {
  id          String     @id @default(cuid())
  walletId    String     @unique
  last4       String
  expiryMonth Int
  expiryYear  Int
  status      CardStatus @default(PENDING)
  limitDaily  Decimal    @default(500) @db.Decimal(14, 2)
  spentToday  Decimal    @default(0) @db.Decimal(14, 2)
  lastResetAt DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

enum CardStatus {
  PENDING
  ACTIVE
  BLOCKED
  CANCELLED
}

// ─── REVIEW ──────────────────────────────────────────────────────────────────
model Review {
  id         String     @id @default(cuid())
  fromType   ReviewFrom
  reviewerId String     // userId de quem avalia
  workerId   String?
  companyId  String?
  shiftId    String
  rating     Int
  comment    String?
  createdAt  DateTime   @default(now())

  worker  Worker?  @relation("WorkerReviews", fields: [workerId], references: [id])
  company Company? @relation("CompanyReviews", fields: [companyId], references: [id])
  shift   Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, shiftId])
  @@index([workerId])
  @@index([companyId])
  @@index([shiftId])
}

enum ReviewFrom {
  WORKER
  COMPANY
}

// ─── NOTIFICATION ────────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

enum NotificationType {
  SHIFT_MATCH
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  CHECKIN_REMINDER
  TIMESHEET_APPROVED
  PAYMENT_SENT
  NEW_APPLICANT
  REVIEW_RECEIVED
  DEPOSIT_CONFIRMED
  WALLET_CASHOUT
}
