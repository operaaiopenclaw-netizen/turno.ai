// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USERS ────────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(WORKER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  worker    Worker?
  company   Company?
}

enum UserRole {
  WORKER
  COMPANY
  ADMIN
}

// ─── WORKER ───────────────────────────────────────────────────────────────────
model Worker {
  id              String   @id @default(cuid())
  userId          String   @unique
  cpf             String   @unique
  phone           String
  bio             String?
  pixKey          String?
  pixKeyType      PixKeyType?
  neighborhood    String?
  city            String   @default("Curitiba")
  state           String   @default("PR")
  latitude        Float?
  longitude       Float?
  rating          Float    @default(0)
  totalShifts     Int      @default(0)
  totalEarnings   Float    @default(0)
  cpfVerified     Boolean  @default(false)
  backgroundCheck BackgroundStatus @default(PENDING)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       WorkerSkill[]
  applications Application[]
  timesheets   Timesheet[]
  reviews      Review[]      @relation("WorkerReviews")
}

enum BackgroundStatus {
  PENDING
  CLEAR
  FLAGGED
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

model WorkerSkill {
  id       String @id @default(cuid())
  workerId String
  skill    String
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

// ─── COMPANY ──────────────────────────────────────────────────────────────────
model Company {
  id           String  @id @default(cuid())
  userId       String  @unique
  cnpj         String  @unique
  tradeName    String
  legalName    String
  phone        String
  address      String
  neighborhood String
  city         String  @default("Curitiba")
  state        String  @default("PR")
  latitude     Float?
  longitude    Float?
  pixKey       String?
  pixKeyType   PixKeyType?
  industry     Industry
  rating       Float   @default(0)
  totalShifts  Int     @default(0)
  verified     Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts   Shift[]
  reviews  Review[]  @relation("CompanyReviews")
}

enum Industry {
  HOSPITALITY
  EVENTS
  RETAIL
  LOGISTICS
  MANUFACTURING
  OTHER
}

// ─── SHIFT ────────────────────────────────────────────────────────────────────
model Shift {
  id           String      @id @default(cuid())
  companyId    String
  role         String
  description  String
  requirements String?
  dresscode    String?
  date         DateTime
  startTime    String      // "18:00"
  endTime      String      // "23:00"
  hours        Float
  payPerHour   Float
  totalPay     Float
  spots        Int         @default(1)
  filledSpots  Int         @default(0)
  category     Industry
  neighborhood String
  address      String?
  city         String      @default("Curitiba")
  latitude     Float?
  longitude    Float?
  status       ShiftStatus @default(OPEN)
  urgent       Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  timesheets   Timesheet[]
  payments     Payment[]
}

enum ShiftStatus {
  DRAFT
  OPEN
  FILLED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── APPLICATION ──────────────────────────────────────────────────────────────
model Application {
  id          String            @id @default(cuid())
  shiftId     String
  workerId    String
  status      ApplicationStatus @default(PENDING)
  message     String?
  appliedAt   DateTime          @default(now())
  decidedAt   DateTime?
  updatedAt   DateTime          @updatedAt

  shift     Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  timesheet Timesheet?
  payment   Payment?

  @@unique([shiftId, workerId])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CONFIRMED   // worker confirmed they will show up
  NO_SHOW
}

// ─── TIMESHEET ────────────────────────────────────────────────────────────────
model Timesheet {
  id             String          @id @default(cuid())
  applicationId  String          @unique
  shiftId        String
  workerId       String
  checkInAt      DateTime?
  checkInLat     Float?
  checkInLng     Float?
  checkOutAt     DateTime?
  checkOutLat    Float?
  checkOutLng    Float?
  hoursWorked    Float?
  status         TimesheetStatus @default(PENDING)
  approvedAt     DateTime?
  disputeNote    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  shift       Shift        @relation(fields: [shiftId], references: [id])
  worker      Worker       @relation(fields: [workerId], references: [id])
  payment     Payment?
}

enum TimesheetStatus {
  PENDING
  APPROVED
  DISPUTED
  RESOLVED
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────────
model Payment {
  id              String        @id @default(cuid())
  shiftId         String
  applicationId   String        @unique
  timesheetId     String?       @unique
  amount          Float
  platformFee     Float
  netAmount       Float
  pixKey          String?
  pixKeyType      PixKeyType?
  pixE2eId        String?       // Pix end-to-end ID
  pixQrCode       String?       // QR code string
  blockchainTxHash String?      // Polygon transaction hash
  blockchainBlock  BigInt?
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  shift        Shift        @relation(fields: [shiftId], references: [id])
  application  Application  @relation(fields: [applicationId], references: [id])
  timesheet    Timesheet?   @relation(fields: [timesheetId], references: [id])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

// ─── REVIEW ──────────────────────────────────────────────────────────────────
model Review {
  id          String   @id @default(cuid())
  fromType    String   // "WORKER" | "COMPANY"
  workerId    String?
  companyId   String?
  rating      Int      // 1-5
  comment     String?
  shiftId     String
  createdAt   DateTime @default(now())

  worker  Worker?  @relation("WorkerReviews", fields: [workerId], references: [id])
  company Company? @relation("CompanyReviews", fields: [companyId], references: [id])
}

// ─── NOTIFICATION ────────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  SHIFT_MATCH
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  CHECKIN_REMINDER
  TIMESHEET_APPROVED
  PAYMENT_SENT
  NEW_APPLICANT
  REVIEW_RECEIVED
}
